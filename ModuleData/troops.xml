    <!-- ═══════════════════════════════════════════════════════════════════
         TIER 3 — Void Weaver
         Elite. High stats, still subject to burn-out. Upgraded from any
         faction Channeler. Rare — costs heavy XP to produce.
         ═══════════════════════════════════════════════════════════════════ -->
    <NPCCharacter id="twa_mage_void_weaver"
                  name="{=twa_mage_void_weaver}Void Weaver"
                  age="35"
                  level="30"
                  culture="Culture.empire"
                  occupation="Soldier"
                  is_template="false"
                  is_hero="false"
                  default_group="Infantry">
        <Attributes
            vigor="6" control="9" endurance="6"
            cunning="8" social="5" intelligence="10"/>
        <Skills>
            <Skill id="OneHanded"  value="120"/>
            <Skill id="Athletics"  value="100"/>
            <Skill id="Throwing"   value="80"/>
        </Skills>
        <Equipments>
            <EquipmentRoster>
                <!-- Better gear — still all Native items -->
                <equipment slot="Item0" id="Item.voulge_2_t4"/>
                <equipment slot="Head"  id="Item.vlandia_leather_helmet_v2"/>
                <equipment slot="Body"  id="Item.lamellar_over_mail"/>
