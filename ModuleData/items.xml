        <ItemComponent><Armor body_armor="0"/></ItemComponent>
        <Description text="[VOID_ANCHOR] Distance is a lie the Gift can correct. Right-Up-Up-Left. Twelve days to drag whatever stands across from you directly to your feet."/>
    </Item>

    <!-- Ashen Vigour  RRDD  20 Days -->
